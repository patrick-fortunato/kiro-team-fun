# Set to 'true' to use real Gemini AI (requires GEMINI_API_KEY)
# Set to 'false' or leave unset to use mock responses (no API key needed)
USE_REAL_AI=false

# Google Gemini API Key (only needed when USE_REAL_AI=true)
# Get yours free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
